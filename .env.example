# ──────────────────────────────────────────────────────────────
# Sunny Sharma Portfolio — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to Git.
# ──────────────────────────────────────────────────────────────

# ── Admin password (bcrypt hash) ───────────────────────────────
# Generate with: node -e "const b=require('bcryptjs'); b.hash('YOUR_PASSWORD',12).then(console.log)"
# Or use: https://bcrypt.online (cost=12)
ADMIN_PASSWORD_HASH=

# ── GitHub API (for auto-deploy on save) ───────────────────────
# 1. Go to GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# 2. Create token with "Contents: Read & Write" permission on your portfolio repo
GITHUB_TOKEN=
GITHUB_OWNER=the-Sunny-Sharma
GITHUB_REPO=portfolio

# ── Resend (contact form emails) ───────────────────────────────
# 1. Sign up free at https://resend.com
# 2. Go to API Keys → Create API Key
RESEND_API_KEY=

# ── Email to receive contact form messages ────────────────────
CONTACT_EMAIL=sunny.sharma.syn@gmail.com

# ── NextAuth (required for session security) ──────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Your production URL (no trailing slash)
NEXTAUTH_URL=https://sunnysharma.vercel.app

# ── Node environment ───────────────────────────────────────────
NODE_ENV=development
